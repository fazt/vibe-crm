generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  OTHER
}

enum InteractionType {
  CALL
  EMAIL
  MEETING
  MESSAGE
  OTHER
}

enum EntityType {
  CLIENT
  COMPANY
  CONTACT
  OPPORTUNITY
  TASK
  NOTE
  ACTIVITY
}

enum NotificationType {
  REMINDER
  TASK_OVERDUE
  OPPORTUNITY_STALE
  FOLLOW_UP
  SYSTEM
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  githubId     String?  @unique
  firstName    String
  lastName     String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships       WorkspaceMember[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  assignedClients   Client[]          @relation("ClientAssignee")
  assignedTasks     Task[]            @relation("TaskAssignee")
  assignedOpps      Opportunity[]       @relation("OpportunityAssignee")
  assignedReminders Reminder[]          @relation("ReminderAssignee")
  activities        Activity[]
  notes             Note[]
  notifications     Notification[]
  auditEvents       AuditEvent[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        WorkspaceMember[]
  companies      Company[]
  clients        Client[]
  contacts       Contact[]
  opportunities  Opportunity[]
  pipelineStages PipelineStage[]
  tasks          Task[]
  notes          Note[]
  activities     Activity[]
  reminders      Reminder[]
  interactions   Interaction[]
  documents      Document[]
  tags           Tag[]
  tagAssignments TagAssignment[]
  notifications  Notification[]
  auditEvents    AuditEvent[]
}

model WorkspaceMember {
  id          String     @id @default(uuid())
  workspaceId String
  userId      String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Company {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  domain      String?
  industry    String?
  size        String?
  website     String?
  phone       String?
  address     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clients   Client[]
  contacts  Contact[]

  @@index([workspaceId])
  @@index([workspaceId, name])
}

model Client {
  id          String       @id @default(uuid())
  workspaceId String
  companyId   String?
  assigneeId  String?
  name        String
  email       String?
  phone       String?
  status      ClientStatus @default(PROSPECT)
  website     String?
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignee      User?         @relation("ClientAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  contacts      Contact[]
  opportunities Opportunity[]
  tasks         Task[]
  notes         Note[]
  activities    Activity[]
  documents     Document[]
  interactions  Interaction[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, name])
}

model Contact {
  id          String   @id @default(uuid())
  workspaceId String
  clientId    String?
  companyId   String?
  firstName   String
  lastName    String
  email       String?
  phone       String?
  jobTitle    String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client        Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  opportunities Opportunity[]
  activities    Activity[]
  notes         Note[]
  interactions  Interaction[]

  @@index([workspaceId])
  @@index([workspaceId, email])
}

model PipelineStage {
  id          String  @id @default(uuid())
  workspaceId String
  name        String
  color       String  @default("#6366f1")
  order       Int
  isWon       Boolean @default(false)
  isLost      Boolean @default(false)

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]

  @@unique([workspaceId, name])
  @@index([workspaceId, order])
}

model Opportunity {
  id                String            @id @default(uuid())
  workspaceId       String
  stageId           String
  clientId          String?
  contactId         String?
  assigneeId        String?
  title             String
  value             Float             @default(0)
  probability       Int               @default(0)
  status            OpportunityStatus @default(OPEN)
  order             Int               @default(0)
  expectedCloseDate DateTime?
  description       String?
  lastActivityAt    DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  workspace  Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stage      PipelineStage @relation(fields: [stageId], references: [id])
  client     Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contact    Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignee   User?         @relation("OpportunityAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  tasks      Task[]
  notes      Note[]
  activities Activity[]

  @@index([workspaceId, stageId])
  @@index([workspaceId, status])
}

model Task {
  id            String       @id @default(uuid())
  workspaceId   String
  clientId      String?
  opportunityId String?
  assigneeId    String?
  title         String
  description   String?
  status        TaskStatus   @default(TODO)
  priority      TaskPriority @default(MEDIUM)
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([workspaceId, dueDate])
}

model Note {
  id            String   @id @default(uuid())
  workspaceId   String
  authorId      String
  clientId      String?
  contactId     String?
  opportunityId String?
  title         String?
  content       String
  aiSummary     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id])
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([clientId])
}

model Activity {
  id            String       @id @default(uuid())
  workspaceId   String
  authorId      String
  clientId      String?
  contactId     String?
  opportunityId String?
  type          ActivityType
  title         String
  description   String?
  duration      Int?
  outcome       String?
  occurredAt    DateTime     @default(now())
  externalId    String?
  source        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id])
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([workspaceId, occurredAt])
}

model Reminder {
  id          String    @id @default(uuid())
  workspaceId String
  assigneeId  String?
  title       String
  message     String?
  dueAt       DateTime
  entityType  EntityType?
  entityId    String?
  sent        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignee  User?     @relation("ReminderAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([workspaceId, dueAt, sent])
}

model Interaction {
  id          String          @id @default(uuid())
  workspaceId String
  clientId    String?
  contactId   String?
  type        InteractionType
  subject     String
  content     String?
  occurredAt  DateTime        @default(now())
  externalId  String?
  source      String?
  createdAt   DateTime        @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([workspaceId, occurredAt])
}

model Document {
  id          String     @id @default(uuid())
  workspaceId String
  entityType  EntityType
  entityId    String
  clientId    String?
  fileName    String
  mimeType    String
  size        Int
  key         String
  url         String?
  uploadedBy  String?
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([workspaceId, entityType, entityId])
}

model Tag {
  id          String @id @default(uuid())
  workspaceId String
  name        String
  color       String @default("#6366f1")

  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignments TagAssignment[]

  @@unique([workspaceId, name])
}

model TagAssignment {
  id          String     @id @default(uuid())
  workspaceId String
  tagId       String
  entityType  EntityType
  entityId    String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, entityType, entityId])
  @@index([workspaceId, entityType, entityId])
}

model Notification {
  id          String           @id @default(uuid())
  workspaceId String
  userId      String
  type        NotificationType
  title       String
  message     String?
  read        Boolean          @default(false)
  emailSent   Boolean          @default(false)
  entityType  EntityType?
  entityId    String?
  createdAt   DateTime         @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model AuditEvent {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
}
