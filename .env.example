JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# DigitalOcean Spaces (S3-compatible)
# Avatars need CORS (PUT + AllowedHeaders: *) and upload with public-read ACL.
