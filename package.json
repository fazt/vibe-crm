{
  "name": "vibe-crm",
  "private": true,
  "version": "0.2.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @vibe-crm/database generate",
    "db:migrate": "pnpm --filter @vibe-crm/database migrate",
    "db:seed": "pnpm --filter @vibe-crm/database seed",
    "db:studio": "pnpm --filter @vibe-crm/database studio",
    "tunnel:api": "cloudflared tunnel --url http://localhost:4000"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
